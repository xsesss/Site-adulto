    <script>
        // ============================================================
        // HEADER SCROLL
        // ============================================================
        const header = document.getElementById('header');
        window.addEventListener('scroll', () => {
            header.classList.toggle('scrolled', window.scrollY > 50);
        });

        // ============================================================
        // TRADUTOR - TOGGLE DO DROPDOWN
        // ============================================================
        const translateToggle = document.getElementById('translateToggle');
        const translateDropdown = document.getElementById('translateDropdown');

        translateToggle.addEventListener('click', (e) => {
            e.stopPropagation();
            translateDropdown.classList.toggle('active');
        });

        document.addEventListener('click', () => {
            translateDropdown.classList.remove('active');
        });

        // ============================================================
        // TRADUTOR - SELECIONAR IDIOMA
        // ============================================================
        document.querySelectorAll('.translate-dropdown a').forEach(item => {
            item.addEventListener('click', function() {
                const lang = this.dataset.lang;
                // Usar o Google Tradutor para traduzir a página
                // O navegador vai perguntar se o usuário quer traduzir
                // Mas também podemos abrir o Google Tradutor com a URL
                const url = `https://translate.google.com/translate?hl=${lang}&sl=pt&u=${encodeURIComponent(window.location.href)}`;
                window.open(url, '_blank');
                translateDropdown.classList.remove('active');
            });
        });

        // ============================================================
        // BANCO DE DADOS
        // ============================================================
        const DB = {
            get: (key, def) => {
                try {
                    const data = localStorage.getItem('xsess_' + key);
                    return data ? JSON.parse(data) : def;
                } catch { return def; }
            },
            set: (key, value) => {
                localStorage.setItem('xsess_' + key, JSON.stringify(value));
            }
        };

        // ============================================================
        // ESTADO
        // ============================================================
        let videos = DB.get('videos', []);
        let likes = DB.get('likes', {});
        let comments = DB.get('comments', {});
        let likedVideos = DB.get('likedVideos', []);
        let views = DB.get('views', {});
        let currentFilter = 'all';
        let currentVideoId = null;

        // ============================================================
        // DOM REFS
        // ============================================================
        const $ = (id) => document.getElementById(id);
        const grid = $('videoGrid');
        const shortsGrid = $('shortsGrid');
        const modal = $('videoModal');
        const modalPlayer = $('modalPlayer');
        const modalTitle = $('modalTitle');
        const modalInfoTitle = $('modalInfoTitle');
        const modalAuthor = $('modalAuthor');
        const modalDate = $('modalDate');
        const modalTag = $('modalTag');
        const modalViews = $('modalViews');
        const modalDesc = $('modalDesc');
        const modalLikeBtn = $('modalLikeBtn');
        const modalLikeBtn2 = $('modalLikeBtn2');
        const modalLikeCount = $('modalLikeCount');
        const modalLikeCount2 = $('modalLikeCount2');
        const modalComments = $('modalComments');
        const suggestionsList = $('suggestionsList');
        const closeModalBtn = $('closeModal');
        const fullscreenBtn = $('modalFullscreenBtn');
        const shareBtn = $('modalShareBtn');
        const shareBtn2 = $('modalShareBtn2');
        const downloadBtn = $('modalDownloadBtn');

        // ============================================================
        // FUNÇÕES AUXILIARES
        // ============================================================
        function formatDate() {
            const now = new Date();
            return now.toLocaleDateString('pt-BR') + ' ' + now.toLocaleTimeString('pt-BR', { hour: '2-digit',
                minute: '2-digit' });
        }

        function getVideoEmbed(url) {
            const yt = url.match(/(?:youtube\.com\/(?:[^\/]+\/.+\/|(?:v|e(?:mbed)?)\/|.*[?&]v=)|youtu\.be\/)([^"&?\/\s]{11})/);
            if (yt) return `<iframe src="https://www.youtube.com/embed/${yt[1]}?autoplay=1&rel=0" allow="autoplay; encrypted-media; fullscreen" allowfullscreen></iframe>`;
            const vimeo = url.match(/vimeo\.com\/(\d+)/);
            if (vimeo) return `<iframe src="https://player.vimeo.com/video/${vimeo[1]}?autoplay=1" allow="autoplay; encrypted-media; fullscreen" allowfullscreen></iframe>`;
            const drive = url.match(/drive\.google\.com\/file\/d\/([^\/]+)/);
            if (drive) return `<iframe src="https://drive.google.com/file/d/${drive[1]}/preview" allow="autoplay" allowfullscreen></iframe>`;
            if (url.match(/\.(mp4|webm|mov|avi)$/i)) {
                return `<video controls autoplay style="width:100%;height:100%;background:#000;">
                            <source src="${url}" type="video/mp4">
                            Seu navegador não suporta vídeo.
                        </video>`;
            }
            return `<iframe src="${url}" allow="autoplay" allowfullscreen></iframe>`;
        }

        function formatViews(n) {
            if (n >= 1000000) return (n / 1000000).toFixed(1) + 'M';
            if (n >= 1000) return (n / 1000).toFixed(1) + 'K';
            return n;
        }

        // ============================================================
        // RENDERIZAR VÍDEOS
        // ============================================================
        function renderVideos(filter = 'all') {
            grid.innerHTML = '';
            shortsGrid.innerHTML = '';

            let filtered = filter === 'all' ? videos : videos.filter(v =>
                v.tags && v.tags.some(t => t.toLowerCase() === filter.toLowerCase())
            );

            const normalVideos = filtered.filter(v => !v.isShort);
            const shortVideos = filtered.filter(v => v.isShort);

            if (normalVideos.length === 0 && shortVideos.length === 0) {
                grid.innerHTML = `
                            <div class="empty-state">
                                <i class="fas fa-film"></i>
                                <div class="text">Nenhum vídeo encontrado</div>
                                <div class="sub">${filter === 'all' ? 'Nenhum vídeo publicado ainda.' : 'Nenhum vídeo com este filtro.'}</div>
                            </div>
                        `;
                return;
            }

            normalVideos.forEach(video => {
                const card = createVideoCard(video);
                grid.appendChild(card);
            });

            shortVideos.forEach(video => {
                const card = createShortCard(video);
                shortsGrid.appendChild(card);
            });
        }

        function createVideoCard(video) {
            const card = document.createElement('div');
            card.className = 'video-card';
            card.dataset.id = video.id;

            const tagsHtml = video.tags ? video.tags.slice(0, 2).map(tag =>
                `<span class="tag">${tag}</span>`
            ).join('') : '';

            card.innerHTML = `
                        <div class="thumb">
                            <img src="${video.thumbnail || 'https://via.placeholder.com/640x360/1a1a1a/cc0033?text=Sem+Imagem'}" alt="${video.title}" loading="lazy" />
                            <div class="overlay"><i class="fas fa-play-circle"></i></div>
                            <span class="duration">${video.duration || '--:--'}</span>
                        </div>
                        <div class="info">
                            <div class="title">${video.title}</div>
                            <div class="meta">
                                <span>${video.date || ''}</span>
                                ${tagsHtml}
                            </div>
                            <div class="author">Criador: <span>${video.author || 'Xsess'}</span></div>
                        </div>
                    `;

            card.addEventListener('click', () => openModal(video.id));
            return card;
        }

        function createShortCard(video) {
            const card = document.createElement('div');
            card.className = 'short-card';
            card.dataset.id = video.id;

            card.innerHTML = `
                        <div class="thumb">
                            <img src="${video.thumbnail || 'https://via.placeholder.com/360x640/1a1a1a/cc0033?text=Short'}" alt="${video.title}" loading="lazy" />
                            <div class="overlay"><i class="fas fa-play"></i></div>
                        </div>
                        <div class="info">
                            <div class="title">${video.title}</div>
                        </div>
                    `;

            card.addEventListener('click', () => openModal(video.id));
            return card;
        }

        // ============================================================
        // SUGESTÕES (PLAYLIST)
        // ============================================================
        function renderSuggestions(currentVideoId) {
            const suggestions = videos.filter(v => v.id !== currentVideoId).slice(0, 5);
            suggestionsList.innerHTML = '';

            if (suggestions.length === 0) {
                suggestionsList.innerHTML =
                    `<p style="color:rgba(255,255,255,0.2);font-size:12px;padding:8px 0;">Nenhuma sugestão disponível</p>`;
                return;
            }

            suggestions.forEach(video => {
                const item = document.createElement('div');
                item.className = 'suggestion-item';
                item.innerHTML = `
                            <div class="thumb">
                                <img src="${video.thumbnail || 'https://via.placeholder.com/60x34/1a1a1a/cc0033?text=Video'}" alt="${video.title}" />
                            </div>
                            <div class="info">
                                <div class="title">${video.title}</div>
                                <div class="meta">${video.author || 'Xsess'}</div>
                            </div>
                        `;
                item.addEventListener('click', () => {
                    openModal(video.id);
                });
                suggestionsList.appendChild(item);
            });
        }

        // ============================================================
        // MODAL - TELA CHEIA
        // ============================================================
        function openModal(videoId) {
            const video = videos.find(v => v.id === videoId);
            if (!video) return;

            currentVideoId = videoId;

            // Incrementar visualizações
            if (!views[videoId]) views[videoId] = 0;
            views[videoId] += 1;
            DB.set('views', views);

            modalPlayer.innerHTML = getVideoEmbed(video.link || '');
            modalTitle.textContent = video.title;
            modalInfoTitle.textContent = video.title;
            modalAuthor.innerHTML = `Criador: <span>${video.author || 'Xsess'}</span>`;
            modalDate.textContent = video.date || '';
            const firstTag = video.tags && video.tags.length > 0 ? video.tags[0] : 'Geral';
            modalTag.textContent = firstTag;
            modalViews.innerHTML = `<i class="fas fa-eye"></i> ${formatViews(views[videoId] || 0)} visualizações`;
            modalDesc.textContent = video.description || 'Sem descrição.';

            const likesCount = likes[videoId] || 0;
            modalLikeCount.textContent = likesCount;
            modalLikeCount2.textContent = likesCount;

            const isLiked = likedVideos.includes(videoId);
            updateLikeButton(modalLikeBtn, isLiked);
            updateLikeButton(modalLikeBtn2, isLiked);

            renderComments(videoId);
            renderSuggestions(videoId);

            modal.classList.add('active');
            document.body.style.overflow = 'hidden';
        }

        function updateLikeButton(btn, isLiked) {
            if (isLiked) {
                btn.classList.add('liked');
                btn.innerHTML = `<i class="fas fa-heart"></i> Curtido`;
            } else {
                btn.classList.remove('liked');
                btn.innerHTML = `<i class="fas fa-heart"></i> Curtir`;
            }
        }

        function closeModal() {
            modal.classList.remove('active');
            document.body.style.overflow = '';
            modalPlayer.innerHTML = '';
            currentVideoId = null;
        }

        // ============================================================
        // FULLSCREEN
        // ============================================================
        fullscreenBtn.addEventListener('click', () => {
            if (!document.fullscreenElement) {
                document.documentElement.requestFullscreen().catch(() => {
                    modal.requestFullscreen();
                });
            } else {
                document.exitFullscreen();
            }
        });

        // ============================================================
        // COMPARTILHAR
        // ============================================================
        function shareVideo() {
            if (navigator.share) {
                navigator.share({
                    title: document.title,
                    text: 'Assista este vídeo no Xsess!',
                    url: window.location.href
                }).catch(() => {});
            } else {
                // Fallback: copiar link
                const url = window.location.href;
                if (navigator.clipboard) {
                    navigator.clipboard.writeText(url).then(() => {
                        alert('Link copiado para a área de transferência!');
                    }).catch(() => {});
                } else {
                    prompt('Copie o link:', url);
                }
            }
        }

        shareBtn.addEventListener('click', shareVideo);
        shareBtn2.addEventListener('click', shareVideo);

        // ============================================================
        // DOWNLOAD
        // ============================================================
        downloadBtn.addEventListener('click', () => {
            const video = videos.find(v => v.id === currentVideoId);
            if (video && video.link) {
                const link = document.createElement('a');
                link.href = video.link;
                link.download = video.title + '.mp4';
                link.target = '_blank';
                document.body.appendChild(link);
                link.click();
                document.body.removeChild(link);
            } else {
                alert('Link para download não disponível.');
            }
        });

        // ============================================================
        // COMENTÁRIOS
        // ============================================================
        function renderComments(videoId) {
            const videoComments = comments[videoId] || [];

            if (videoComments.length === 0) {
                modalComments.innerHTML =
                    `<p style="color:rgba(255,255,255,0.15);font-size:12px;padding:6px 0;">Nenhum comentário ainda. Seja o primeiro!</p>`;
                return;
            }

            modalComments.innerHTML = videoComments.map(c => `
                        <div class="comment">
                            <div class="comment-author">${c.name}</div>
                            <div class="comment-content">${c.text}</div>
                            <div class="comment-date">${c.date}</div>
                        </div>
                    `).join('');
        }

        function submitComment(videoId, name, text) {
            if (!comments[videoId]) comments[videoId] = [];
            comments[videoId].push({
                name: name.trim(),
                text: text.trim(),
                date: formatDate()
            });
            DB.set('comments', comments);
            renderComments(videoId);
            $('commentName').value = '';
            $('commentText').value = '';
        }

        // ============================================================
        // CURTIR
        // ============================================================
        function toggleLike(videoId) {
            if (!likes[videoId]) likes[videoId] = 0;

            const isLiked = likedVideos.includes(videoId);

            if (isLiked) {
                likedVideos = likedVideos.filter(id => id !== videoId);
                likes[videoId] = Math.max(0, likes[videoId] - 1);
            } else {
                likedVideos.push(videoId);
                likes[videoId] = (likes[videoId] || 0) + 1;
            }

            DB.set('likes', likes);
            DB.set('likedVideos', likedVideos);

            const likesCount = likes[videoId];
            modalLikeCount.textContent = likesCount;
            modalLikeCount2.textContent = likesCount;

            updateLikeButton(modalLikeBtn, likedVideos.includes(videoId));
            updateLikeButton(modalLikeBtn2, likedVideos.includes(videoId));
        }

        // ============================================================
        // EVENTOS
        // ============================================================
        document.querySelectorAll('.filter-btn').forEach(btn => {
            btn.addEventListener('click', function() {
                document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
                this.classList.add('active');
                currentFilter = this.dataset.filter;
                renderVideos(currentFilter);
            });
        });

        modalLikeBtn.addEventListener('click', function() {
            if (currentVideoId) toggleLike(currentVideoId);
        });
        modalLikeBtn2.addEventListener('click', function() {
            if (currentVideoId) toggleLike(currentVideoId);
        });

        closeModalBtn.addEventListener('click', closeModal);
        modal.addEventListener('click', function(e) {
            if (e.target === this) closeModal();
        });
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') closeModal();
        });

        $('commentForm').addEventListener('submit', function(e) {
            e.preventDefault();
            const name = $('commentName').value.trim();
            const text = $('commentText').value.trim();
            if (!name || !text || !currentVideoId) return;
            submitComment(currentVideoId, name, text);
        });

        // ============================================================
        // ATIVAR ANÚNCIOS
        // ============================================================
        // document.querySelectorAll('.ad-container').forEach(el => el.style.display = 'block');

        // ============================================================
        // INICIAR
        // ============================================================
        renderVideos('all');
    </script>

</body>
</html>
