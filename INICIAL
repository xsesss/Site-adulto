<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0" />
    <meta name="theme-color" content="#0a0a0a" />
    <title>Xsess · Streaming +18</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <style>
        /* ============================================================
           RESET E BASE
           ============================================================ */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html,
        body {
            width: 100%;
            min-height: 100vh;
            background: #0a0a0a;
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
            color: #f0f0f0;
            -webkit-font-smoothing: antialiased;
        }

        ::-webkit-scrollbar {
            width: 4px;
        }
        ::-webkit-scrollbar-track {
            background: transparent;
        }
        ::-webkit-scrollbar-thumb {
            background: #cc0033;
            border-radius: 2px;
        }

        a {
            text-decoration: none;
            color: inherit;
        }
        img {
            display: block;
            max-width: 100%;
        }

        /* ============================================================
           HEADER - COM TRADUTOR
           ============================================================ */
        .header {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1000;
            padding: 14px 48px;
            background: linear-gradient(180deg, rgba(0, 0, 0, 0.8) 0%, transparent 100%);
            display: flex;
            justify-content: space-between;
            align-items: center;
            transition: all 0.4s ease;
        }

        .header.scrolled {
            background: rgba(10, 10, 10, 0.96);
            backdrop-filter: blur(16px);
            border-bottom: 1px solid rgba(255, 255, 255, 0.04);
            padding: 10px 48px;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .logo img {
            height: 34px;
            width: auto;
        }

        .logo span {
            font-size: 20px;
            font-weight: 800;
            color: #fff;
            letter-spacing: -0.5px;
        }

        .logo span em {
            color: #cc0033;
            font-style: normal;
        }

        .nav-links {
            display: flex;
            align-items: center;
            gap: 28px;
        }

        .nav-links a {
            font-size: 13px;
            font-weight: 500;
            color: rgba(255, 255, 255, 0.5);
            transition: color 0.3s;
            position: relative;
        }

        .nav-links a::after {
            content: '';
            position: absolute;
            bottom: -4px;
            left: 0;
            width: 0;
            height: 2px;
            background: #cc0033;
            transition: width 0.3s ease;
        }

        .nav-links a:hover,
        .nav-links a.active {
            color: #fff;
        }

        .nav-links a:hover::after,
        .nav-links a.active::after {
            width: 100%;
        }

        .nav-links .badge {
            background: #cc0033;
            padding: 2px 14px;
            border-radius: 20px;
            font-size: 10px;
            font-weight: 700;
            color: #fff;
            letter-spacing: 0.5px;
        }

        .header-actions {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .header-actions .icon-btn {
            background: none;
            border: none;
            color: rgba(255, 255, 255, 0.4);
            font-size: 17px;
            cursor: pointer;
            transition: color 0.3s;
            padding: 6px;
        }

        .header-actions .icon-btn:hover {
            color: #fff;
        }

        /* ============================================================
           TRADUTOR - BOTÃO ELEGANTE
           ============================================================ */
        .translate-container {
            position: relative;
            display: inline-block;
        }

        .translate-btn {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 6px 14px;
            background: rgba(255, 255, 255, 0.06);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 30px;
            color: rgba(255, 255, 255, 0.6);
            font-size: 12px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.3s ease;
            font-family: 'Inter', sans-serif;
        }

        .translate-btn:hover {
            background: rgba(255, 255, 255, 0.1);
            border-color: rgba(204, 0, 51, 0.2);
            color: #fff;
        }

        .translate-btn i {
            font-size: 14px;
        }

        .translate-dropdown {
            display: none;
            position: absolute;
            top: 110%;
            right: 0;
            background: #1a1a1a;
            border: 1px solid #2a2a2a;
            border-radius: 12px;
            padding: 8px 0;
            min-width: 160px;
            box-shadow: 0 16px 48px rgba(0, 0, 0, 0.6);
            z-index: 100;
        }

        .translate-dropdown.active {
            display: block;
        }

        .translate-dropdown a {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 8px 20px;
            color: rgba(255, 255, 255, 0.6);
            font-size: 13px;
            transition: all 0.3s ease;
            cursor: pointer;
        }

        .translate-dropdown a:hover {
            background: rgba(204, 0, 51, 0.08);
            color: #fff;
        }

        .translate-dropdown a i {
            font-size: 16px;
            width: 20px;
        }

        /* ============================================================
           HERO
           ============================================================ */
        .hero {
            position: relative;
            width: 100%;
            height: 75vh;
            min-height: 400px;
            max-height: 650px;
            background: #0a0a0a;
            overflow: hidden;
            margin-top: 0;
        }

        .hero .bg-image {
            width: 100%;
            height: 100%;
            object-fit: cover;
            object-position: center top;
            filter: brightness(0.45);
            transition: transform 8s ease;
        }

        .hero:hover .bg-image {
            transform: scale(1.04);
        }

        .hero .overlay {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            height: 70%;
            background: linear-gradient(0deg, #0a0a0a 6%, transparent 100%);
            pointer-events: none;
        }

        .hero .content {
            position: absolute;
            bottom: 20%;
            left: 56px;
            max-width: 520px;
            z-index: 10;
        }

        .hero .content .logo-hero {
            height: 50px;
            width: auto;
            margin-bottom: 10px;
        }

        .hero .content h1 {
            font-size: 38px;
            font-weight: 900;
            letter-spacing: -1px;
            color: #fff;
            line-height: 1.1;
            margin-bottom: 4px;
        }

        .hero .content h1 em {
            color: #cc0033;
            font-style: normal;
        }

        .hero .content p {
            font-size: 15px;
            color: rgba(255, 255, 255, 0.6);
            max-width: 420px;
            line-height: 1.6;
            margin-bottom: 14px;
        }

        .hero .content .tags {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
            margin-bottom: 16px;
        }

        .hero .content .tags span {
            background: rgba(204, 0, 51, 0.12);
            border: 1px solid rgba(204, 0, 51, 0.2);
            padding: 4px 16px;
            border-radius: 20px;
            font-size: 10px;
            font-weight: 600;
            color: #cc0033;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .hero .content .buttons {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
        }

        .btn-play {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            padding: 10px 28px;
            background: #cc0033;
            border: none;
            border-radius: 30px;
            color: #fff;
            font-weight: 700;
            font-size: 13px;
            cursor: pointer;
            transition: all 0.3s ease;
            font-family: 'Inter', sans-serif;
        }

        .btn-play:hover {
            background: #b3002e;
            transform: translateY(-2px);
            box-shadow: 0 8px 30px rgba(204, 0, 51, 0.25);
        }

        .btn-play i {
            font-size: 13px;
        }

        .btn-info {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            padding: 10px 24px;
            background: rgba(255, 255, 255, 0.06);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 30px;
            color: #ddd;
            font-weight: 600;
            font-size: 13px;
            cursor: pointer;
            transition: all 0.3s ease;
            font-family: 'Inter', sans-serif;
        }

        .btn-info:hover {
            background: rgba(255, 255, 255, 0.1);
            border-color: rgba(255, 255, 255, 0.15);
        }

        /* ============================================================
           MAIN
           ============================================================ */
        .main-content {
            padding: 0 48px 48px;
            margin-top: -48px;
            position: relative;
            z-index: 20;
        }

        .section {
            margin-bottom: 36px;
        }

        .section-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 14px;
        }

        .section-header h2 {
            font-size: 19px;
            font-weight: 700;
            color: #fff;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .section-header h2 em {
            color: #cc0033;
            font-style: normal;
        }

        .section-header .see-all {
            color: rgba(255, 255, 255, 0.3);
            font-size: 12px;
            font-weight: 500;
            transition: color 0.3s;
            cursor: pointer;
        }

        .section-header .see-all:hover {
            color: #cc0033;
        }

        /* ============================================================
           FILTROS
           ============================================================ */
        .filter-bar {
            display: flex;
            gap: 6px;
            flex-wrap: wrap;
            margin-bottom: 18px;
        }

        .filter-btn {
            padding: 5px 16px;
            border: 1px solid rgba(255, 255, 255, 0.06);
            border-radius: 30px;
            background: transparent;
            color: rgba(255, 255, 255, 0.35);
            font-size: 11px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.3s ease;
            font-family: 'Inter', sans-serif;
        }

        .filter-btn:hover {
            border-color: rgba(204, 0, 51, 0.2);
            color: #fff;
        }

        .filter-btn.active {
            background: #cc0033;
            border-color: #cc0033;
            color: #fff;
        }

        /* ============================================================
           GRID
           ============================================================ */
        .video-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
            gap: 18px;
        }

        .video-card {
            background: #111;
            border-radius: 12px;
            overflow: hidden;
            transition: all 0.4s ease;
            cursor: pointer;
            border: 1px solid rgba(255, 255, 255, 0.02);
        }

        .video-card:hover {
            transform: translateY(-4px);
            border-color: rgba(204, 0, 51, 0.12);
            box-shadow: 0 16px 48px rgba(0, 0, 0, 0.4);
        }

        .video-card .thumb {
            position: relative;
            width: 100%;
            padding-top: 56.25%;
            background: #1a1a1a;
            overflow: hidden;
        }

        .video-card .thumb img {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.5s ease;
        }

        .video-card:hover .thumb img {
            transform: scale(1.04);
        }

        .video-card .thumb .overlay {
            position: absolute;
            inset: 0;
            display: flex;
            justify-content: center;
            align-items: center;
            background: rgba(0, 0, 0, 0.2);
            opacity: 0;
            transition: opacity 0.4s ease;
        }

        .video-card:hover .thumb .overlay {
            opacity: 1;
        }

        .video-card .thumb .overlay i {
            font-size: 38px;
            color: #fff;
            text-shadow: 0 4px 30px rgba(0, 0, 0, 0.3);
            transform: scale(0.9);
            transition: transform 0.4s ease;
        }

        .video-card:hover .thumb .overlay i {
            transform: scale(1);
        }

        .video-card .thumb .duration {
            position: absolute;
            bottom: 8px;
            right: 10px;
            background: rgba(0, 0, 0, 0.7);
            padding: 2px 10px;
            border-radius: 12px;
            font-size: 10px;
            font-weight: 500;
            color: #fff;
        }

        .video-card .info {
            padding: 12px 14px 14px;
        }

        .video-card .info .title {
            font-size: 14px;
            font-weight: 600;
            color: #fff;
            line-height: 1.3;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .video-card .info .meta {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 10px;
            color: rgba(255, 255, 255, 0.3);
            margin-top: 5px;
            flex-wrap: wrap;
        }

        .video-card .info .meta .tag {
            color: #cc0033;
            font-weight: 600;
            font-size: 8px;
            text-transform: uppercase;
            border: 1px solid rgba(204, 0, 51, 0.12);
            padding: 1px 10px;
            border-radius: 12px;
            letter-spacing: 0.5px;
        }

        .video-card .info .author {
            color: rgba(255, 255, 255, 0.2);
            font-size: 10px;
            margin-top: 3px;
        }

        .video-card .info .author span {
            color: #cc0033;
        }

        /* ============================================================
           SHORTS
           ============================================================ */
        .shorts-section {
            margin-top: 30px;
            padding-top: 30px;
            border-top: 1px solid rgba(255, 255, 255, 0.04);
        }

        .shorts-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
            gap: 12px;
        }

        .short-card {
            position: relative;
            background: #111;
            border-radius: 12px;
            overflow: hidden;
            transition: all 0.4s ease;
            cursor: pointer;
            aspect-ratio: 9/16;
            border: 1px solid rgba(255, 255, 255, 0.02);
        }

        .short-card:hover {
            transform: translateY(-4px);
            border-color: rgba(204, 0, 51, 0.12);
            box-shadow: 0 16px 48px rgba(0, 0, 0, 0.4);
        }

        .short-card .thumb {
            width: 100%;
            height: 100%;
            overflow: hidden;
        }

        .short-card .thumb img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.5s ease;
        }

        .short-card:hover .thumb img {
            transform: scale(1.04);
        }

        .short-card .overlay {
            position: absolute;
            inset: 0;
            display: flex;
            justify-content: center;
            align-items: center;
            background: rgba(0, 0, 0, 0.15);
            opacity: 0;
            transition: opacity 0.4s ease;
        }

        .short-card:hover .overlay {
            opacity: 1;
        }

        .short-card .overlay i {
            font-size: 26px;
            color: #fff;
            text-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
        }

        .short-card .info {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            padding: 8px 10px;
            background: linear-gradient(0deg, rgba(0, 0, 0, 0.7) 0%, transparent 100%);
        }

        .short-card .info .title {
            font-size: 10px;
            font-weight: 500;
            color: #fff;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
            line-height: 1.3;
        }

        /* ============================================================
           MODAL - TELA CHEIA COM MAIS FUNCIONALIDADES
           ============================================================ */
        .modal-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, 0.96);
            z-index: 9999;
            justify-content: center;
            align-items: center;
            padding: 0;
        }

        .modal-overlay.active {
            display: flex;
        }

        .modal-content {
            position: relative;
            width: 100%;
            height: 100%;
            max-height: 100vh;
            background: #0a0a0a;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        /* Header do modal */
        .modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 10px 20px;
            background: rgba(0, 0, 0, 0.6);
            flex-shrink: 0;
            z-index: 10;
            backdrop-filter: blur(8px);
        }

        .modal-header .modal-title {
            font-size: 15px;
            font-weight: 600;
            color: #fff;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            max-width: 40%;
        }

        .modal-header .modal-actions {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .modal-header .modal-actions button {
            background: none;
            border: none;
            color: rgba(255, 255, 255, 0.5);
            font-size: 15px;
            cursor: pointer;
            transition: color 0.3s;
            padding: 4px;
        }

        .modal-header .modal-actions button:hover {
            color: #fff;
        }

        .modal-header .modal-actions .close-btn {
            font-size: 20px;
        }

        /* Player */
        .modal-player {
            flex: 1;
            background: #000;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 0;
            position: relative;
        }

        .modal-player video,
        .modal-player iframe {
            width: 100%;
            height: 100%;
            border: none;
            display: block;
            max-width: 100%;
            max-height: 100%;
            object-fit: contain;
        }

        /* Controles do player */
        .player-controls {
            position: absolute;
            bottom: 20px;
            left: 50%;
            transform: translateX(-50%);
            display: flex;
            align-items: center;
            gap: 16px;
            background: rgba(0, 0, 0, 0.7);
            padding: 8px 20px;
            border-radius: 30px;
            backdrop-filter: blur(8px);
            opacity: 0;
            transition: opacity 0.4s ease;
        }

        .modal-player:hover .player-controls {
            opacity: 1;
        }

        .player-controls button {
            background: none;
            border: none;
            color: rgba(255, 255, 255, 0.7);
            font-size: 16px;
            cursor: pointer;
            transition: color 0.3s;
            padding: 4px;
        }

        .player-controls button:hover {
            color: #fff;
        }

        .player-controls .progress-bar {
            width: 200px;
            height: 3px;
            background: rgba(255, 255, 255, 0.2);
            border-radius: 2px;
            position: relative;
            cursor: pointer;
        }

        .player-controls .progress-bar .progress-fill {
            width: 0%;
            height: 100%;
            background: #cc0033;
            border-radius: 2px;
            transition: width 0.1s;
        }

        .player-controls .time {
            font-size: 11px;
            color: rgba(255, 255, 255, 0.6);
            font-weight: 500;
            min-width: 80px;
            text-align: center;
        }

        /* Info do modal */
        .modal-info {
            padding: 12px 20px 16px;
            background: #0a0a0a;
            border-top: 1px solid rgba(255, 255, 255, 0.04);
            max-height: 35vh;
            overflow-y: auto;
            flex-shrink: 0;
        }

        .modal-info .info-title {
            font-size: 17px;
            font-weight: 700;
            color: #fff;
            margin-bottom: 2px;
        }

        .modal-info .info-author {
            color: rgba(255, 255, 255, 0.35);
            font-size: 12px;
        }

        .modal-info .info-author span {
            color: #cc0033;
        }

        .modal-info .info-meta {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 11px;
            color: rgba(255, 255, 255, 0.2);
            margin-bottom: 8px;
            flex-wrap: wrap;
        }

        .modal-info .info-meta .tag {
            color: #cc0033;
            font-weight: 600;
            font-size: 9px;
            text-transform: uppercase;
            border: 1px solid rgba(204, 0, 51, 0.12);
            padding: 1px 12px;
            border-radius: 12px;
        }

        .modal-info .info-desc {
            color: rgba(255, 255, 255, 0.5);
            font-size: 12px;
            line-height: 1.6;
            margin-bottom: 8px;
        }

        .modal-info .info-actions {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 8px 0;
            border-top: 1px solid rgba(255, 255, 255, 0.04);
            border-bottom: 1px solid rgba(255, 255, 255, 0.04);
            flex-wrap: wrap;
        }

        .modal-info .info-actions .btn-icon {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 5px 12px;
            background: transparent;
            border: 1px solid rgba(255, 255, 255, 0.06);
            border-radius: 30px;
            color: rgba(255, 255, 255, 0.5);
            font-size: 12px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.3s ease;
            font-family: 'Inter', sans-serif;
        }

        .modal-info .info-actions .btn-icon:hover {
            border-color: rgba(204, 0, 51, 0.2);
            color: #fff;
        }

        .modal-info .info-actions .btn-icon.liked {
            background: #cc0033;
            border-color: #cc0033;
            color: #fff;
        }

        .modal-info .info-actions .btn-icon i {
            font-size: 13px;
        }

        .modal-info .info-actions .count {
            color: rgba(255, 255, 255, 0.3);
            font-size: 12px;
            font-weight: 500;
        }

        /* ============================================================
           COMENTÁRIOS
           ============================================================ */
        .comments-section {
            margin-top: 8px;
        }

        .comments-section h4 {
            font-size: 13px;
            font-weight: 600;
            color: #fff;
            margin-bottom: 8px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .comments-section h4 i {
            color: rgba(255, 255, 255, 0.15);
        }

        .comment {
            background: rgba(255, 255, 255, 0.02);
            padding: 8px 12px;
            border-radius: 8px;
            border: 1px solid rgba(255, 255, 255, 0.02);
            margin-bottom: 6px;
        }

        .comment .comment-author {
            color: #cc0033;
            font-weight: 600;
            font-size: 11px;
        }

        .comment .comment-content {
            color: rgba(255, 255, 255, 0.65);
            margin-top: 2px;
            font-size: 11px;
            line-height: 1.5;
        }

        .comment .comment-date {
            color: rgba(255, 255, 255, 0.15);
            font-size: 9px;
            margin-top: 2px;
        }

        .comment-form {
            display: flex;
            flex-direction: column;
            gap: 6px;
            margin-top: 8px;
        }

        .comment-form input,
        .comment-form textarea {
            width: 100%;
            padding: 8px 12px;
