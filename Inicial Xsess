<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0" />
    <meta name="theme-color" content="#0a0a0a" />
    <title>Xsess · Conteúdo +18 Premium</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;800;900&display=swap" rel="stylesheet" />
    <style>
        /* ============================================================
           RESET E BASE
           ============================================================ */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html,
        body {
            width: 100%;
            min-height: 100vh;
            background: #0a0a0a;
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
            color: #f0f0f0;
            -webkit-font-smoothing: antialiased;
        }

        ::-webkit-scrollbar {
            width: 6px;
        }
        ::-webkit-scrollbar-track {
            background: #0a0a0a;
        }
        ::-webkit-scrollbar-thumb {
            background: #cc0033;
            border-radius: 0;
        }

        a {
            text-decoration: none;
            color: inherit;
        }

        /* ============================================================
           HEADER - ESTILO NETFLIX
           ============================================================ */
        .header {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 100;
            padding: 16px 40px;
            background: linear-gradient(180deg, rgba(0, 0, 0, 0.9) 0%, transparent 100%);
            display: flex;
            justify-content: space-between;
            align-items: center;
            transition: background 0.3s;
        }

        .header.scrolled {
            background: #0a0a0a;
            border-bottom: 1px solid #1a1a1a;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .logo img {
            height: 40px;
            width: auto;
            object-fit: contain;
        }

        .header-nav {
            display: flex;
            align-items: center;
            gap: 28px;
            font-size: 14px;
            font-weight: 600;
            color: #aaa;
        }

        .header-nav a {
            transition: color 0.25s;
            padding: 4px 0;
            border-bottom: 2px solid transparent;
        }

        .header-nav a:hover,
        .header-nav a.active {
            color: #fff;
        }

        .header-nav a.active {
            border-bottom-color: #cc0033;
        }

        .header-nav .badge {
            background: #cc0033;
            padding: 4px 14px;
            color: #fff;
            font-size: 11px;
            font-weight: 700;
            border-radius: 2px;
        }

        .header-actions {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .header-actions .search-btn {
            background: none;
            border: none;
            color: #aaa;
            cursor: pointer;
            transition: color 0.25s;
        }

        .header-actions .search-btn:hover {
            color: #fff;
        }

        .header-actions .search-btn svg {
            width: 22px;
            height: 22px;
            fill: none;
            stroke: currentColor;
            stroke-width: 2;
            stroke-linecap: round;
            stroke-linejoin: round;
        }

        /* ============================================================
           HERO BANNER - ESTILO NETFLIX
           ============================================================ */
        .hero-banner {
            position: relative;
            width: 100%;
            height: 70vh;
            min-height: 420px;
            max-height: 700px;
            background: #0a0a0a;
            overflow: hidden;
            margin-top: 0;
        }

        .hero-banner .banner-image {
            width: 100%;
            height: 100%;
            object-fit: cover;
            object-position: center top;
        }

        .hero-banner .banner-overlay {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            height: 60%;
            background: linear-gradient(0deg, #0a0a0a 10%, transparent 100%);
        }

        .hero-banner .banner-content {
            position: absolute;
            bottom: 20%;
            left: 40px;
            max-width: 560px;
        }

        .hero-banner .banner-content .logo-banner {
            max-height: 70px;
            width: auto;
            margin-bottom: 12px;
        }

        .hero-banner .banner-content p {
            font-size: 18px;
            color: #ccc;
            max-width: 480px;
            line-height: 1.6;
            margin-bottom: 16px;
        }

        .hero-banner .banner-content .banner-tags {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            margin-bottom: 20px;
        }

        .hero-banner .banner-content .banner-tags span {
            background: rgba(204, 0, 51, 0.2);
            border: 1px solid rgba(204, 0, 51, 0.3);
            padding: 4px 16px;
            font-size: 12px;
            font-weight: 600;
            color: #cc0033;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .hero-banner .banner-content .banner-buttons {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
        }

        .hero-banner .banner-content .btn-play {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 12px 32px;
            background: #cc0033;
            border: none;
            color: #fff;
            font-weight: 700;
            font-size: 16px;
            cursor: pointer;
            transition: all 0.25s;
            font-family: 'Inter', sans-serif;
        }

        .hero-banner .banner-content .btn-play:hover {
            background: #b3002e;
            transform: scale(1.02);
        }

        .hero-banner .banner-content .btn-play svg {
            width: 20px;
            height: 20px;
            fill: none;
            stroke: currentColor;
            stroke-width: 2.5;
            stroke-linecap: round;
            stroke-linejoin: round;
        }

        .hero-banner .banner-content .btn-info {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 12px 28px;
            background: rgba(255, 255, 255, 0.08);
            border: 1px solid rgba(255, 255, 255, 0.15);
            color: #ddd;
            font-weight: 600;
            font-size: 16px;
            cursor: pointer;
            transition: all 0.25s;
            font-family: 'Inter', sans-serif;
        }

        .hero-banner .banner-content .btn-info:hover {
            background: rgba(255, 255, 255, 0.15);
        }

        .hero-banner .banner-content .btn-info svg {
            width: 20px;
            height: 20px;
            fill: none;
            stroke: currentColor;
            stroke-width: 2;
            stroke-linecap: round;
            stroke-linejoin: round;
        }

        /* ============================================================
           CONTEÚDO PRINCIPAL
           ============================================================ */
        .main-content {
            padding: 0 40px 40px;
            margin-top: -40px;
            position: relative;
            z-index: 10;
        }

        /* ============================================================
           SEÇÕES - ESTILO NETFLIX
           ============================================================ */
        .section {
            margin-bottom: 40px;
        }

        .section-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 16px;
        }

        .section-header h2 {
            font-size: 22px;
            font-weight: 700;
            color: #fff;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .section-header h2 span {
            color: #cc0033;
        }

        .section-header .see-all {
            color: #888;
            font-size: 14px;
            font-weight: 600;
            transition: color 0.25s;
            cursor: pointer;
        }

        .section-header .see-all:hover {
            color: #cc0033;
        }

        /* ============================================================
           FILTROS - ESTILO NETFLIX
           ============================================================ */
        .filter-bar {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
            padding: 8px 0 16px;
            margin-bottom: 8px;
        }

        .filter-btn {
            padding: 6px 20px;
            border: 1px solid #2a2a2a;
            background: transparent;
            color: #888;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.25s;
            font-family: 'Inter', sans-serif;
            border-radius: 2px;
        }

        .filter-btn:hover {
            border-color: #cc0033;
            color: #fff;
        }

        .filter-btn.active {
            background: #cc0033;
            border-color: #cc0033;
            color: #fff;
        }

        /* ============================================================
           GRID DE VÍDEOS - ESTILO NETFLIX
           ============================================================ */
        .video-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
            gap: 20px;
        }

        .video-card {
            background: #111;
            border: 1px solid #1a1a1a;
            overflow: hidden;
            transition: all 0.3s;
            cursor: pointer;
            position: relative;
        }

        .video-card:hover {
            border-color: #cc0033;
            transform: translateY(-6px);
            box-shadow: 0 16px 48px rgba(204, 0, 51, 0.08);
        }

        .video-card .thumb {
            position: relative;
            width: 100%;
            padding-top: 56.25%;
            background: #1a1a1a;
            overflow: hidden;
        }

        .video-card .thumb img {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.5s;
        }

        .video-card:hover .thumb img {
            transform: scale(1.06);
        }

        .video-card .thumb .overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            display: flex;
            justify-content: center;
            align-items: center;
            background: rgba(0, 0, 0, 0.3);
            transition: background 0.3s;
        }

        .video-card:hover .thumb .overlay {
            background: rgba(0, 0, 0, 0.05);
        }

        .video-card .thumb .play-icon {
            width: 52px;
            height: 52px;
            fill: none;
            stroke: #fff;
            stroke-width: 2;
            filter: drop-shadow(0 4px 30px rgba(204, 0, 51, 0.4));
            transition: all 0.3s;
        }

        .video-card:hover .thumb .play-icon {
            transform: scale(1.15);
            stroke: #cc0033;
        }

        .video-card .thumb .duration {
            position: absolute;
            bottom: 10px;
            right: 12px;
            background: rgba(0, 0, 0, 0.85);
            padding: 3px 12px;
            font-size: 12px;
            font-weight: 600;
            color: #fff;
            border-radius: 2px;
        }

        .video-card .info {
            padding: 14px 16px 16px;
        }

        .video-card .info .title {
            font-size: 15px;
            font-weight: 700;
            color: #fff;
            line-height: 1.3;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .video-card .info .meta {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 12px;
            color: #666;
            margin-top: 6px;
            flex-wrap: wrap;
        }

        .video-card .info .meta .tag {
            color: #cc0033;
            font-weight: 600;
            font-size: 10px;
            text-transform: uppercase;
            border: 1px solid #2a1a1a;
            padding: 1px 10px;
            border-radius: 2px;
            letter-spacing: 0.3px;
        }

        .video-card .info .author {
            color: #555;
            font-size: 12px;
            margin-top: 4px;
        }

        .video-card .info .author span {
            color: #cc0033;
        }

        /* ============================================================
           MODAL DO VÍDEO
           ============================================================ */
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.95);
            z-index: 999;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

        .modal.active {
            display: flex;
        }

        .modal-content {
            position: relative;
            width: 100%;
            max-width: 960px;
            max-height: 92vh;
            overflow-y: auto;
            background: #0a0a0a;
            border: 1px solid #1a1a1a;
            padding: 30px;
        }

        .modal-content .close {
            position: absolute;
            top: 12px;
            right: 20px;
            font-size: 30px;
            color: #888;
            cursor: pointer;
            transition: color 0.25s;
            z-index: 10;
            background: none;
            border: none;
            font-family: 'Inter', sans-serif;
        }

        .modal-content .close:hover {
            color: #fff;
        }

        .modal-content .player {
            width: 100%;
            aspect-ratio: 16/9;
            background: #000;
            margin-bottom: 16px;
        }

        .modal-content .player iframe,
        .modal-content .player video {
            width: 100%;
            height: 100%;
            border: none;
        }

        .modal-content .modal-title {
            font-size: 24px;
            font-weight: 800;
            color: #fff;
            margin-bottom: 2px;
        }

        .modal-content .modal-author {
            color: #888;
            font-size: 14px;
            margin-bottom: 2px;
        }

        .modal-content .modal-author span {
            color: #cc0033;
            font-weight: 600;
        }

        .modal-content .modal-meta {
            display: flex;
            align-items: center;
            gap: 12px;
            font-size: 14px;
            color: #666;
            margin-bottom: 14px;
            flex-wrap: wrap;
        }

        .modal-content .modal-meta .tag {
            color: #cc0033;
            font-weight: 600;
            font-size: 11px;
            text-transform: uppercase;
            border: 1px solid #2a1a1a;
            padding: 2px 14px;
            border-radius: 2px;
        }

        .modal-content .modal-desc {
            color: #aaa;
            font-size: 15px;
            line-height: 1.7;
            margin-bottom: 16px;
        }

        .modal-content .modal-actions {
            display: flex;
            align-items: center;
            gap: 16px;
            padding: 14px 0;
            border-top: 1px solid #1a1a1a;
            border-bottom: 1px solid #1a1a1a;
            margin: 14px 0;
        }

        .like-btn {
            display: flex;
            align-items: center;
            gap: 10px;
            background: transparent;
            border: 1px solid #2a2a2a;
            padding: 8px 22px;
            color: #888;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.25s;
            font-family: 'Inter', sans-serif;
            border-radius: 2px;
        }

        .like-btn:hover {
            border-color: #cc0033;
            color: #cc0033;
        }

        .like-btn.liked {
            background: #cc0033;
            border-color: #cc0033;
            color: #fff;
        }

        .like-btn svg {
            width: 22px;
            height: 22px;
            fill: none;
            stroke: currentColor;
            stroke-width: 2;
            stroke-linecap: round;
            stroke-linejoin: round;
        }

        .like-count {
            color: #888;
            font-size: 15px;
            font-weight: 600;
        }

        /* ============================================================
           COMENTÁRIOS NO MODAL
           ============================================================ */
        .comments-section {
            margin-top: 16px;
        }

        .comments-section h3 {
            color: #fff;
            font-size: 17px;
            margin-bottom: 14px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .comments-section h3 svg {
            width: 20px;
            height: 20px;
            fill: none;
            stroke: currentColor;
            stroke-width: 2;
            stroke-linecap: round;
            stroke-linejoin: round;
        }

        .comment {
            background: #111;
            padding: 12px 16px;
            border: 1px solid #1a1a1a;
            margin-bottom: 8px;
            border-radius: 2px;
        }

        .comment .comment-author {
            color: #cc0033;
            font-weight: 700;
            font-size: 14px;
        }

        .comment .comment-content {
            color: #aaa;
            margin-top: 4px;
            font-size: 14px;
        }

        .comment .comment-date {
            color: #555;
            font-size: 12px;
            margin-top: 4px;
        }

        .comment-form input,
        .comment-form textarea {
            width: 100%;
            padding: 10px 14px;
            background: #0a0a0a;
            border: 1px solid #2a2a2a;
            color: #fff;
            font-size: 14px;
            font-family: 'Inter', sans-serif;
            margin-bottom: 8px;
            transition: border-color 0.25s;
            border-radius: 2px;
        }

        .comment-form input:focus,
        .comment-form textarea:focus {
            border-color: #cc0033;
            outline: none;
        }

        .comment-form .comment-submit {
            background: #cc0033;
            border: none;
            padding: 10px 28px;
            color: #fff;
            font-weight: 700;
            cursor: pointer;
            transition: background 0.25s;
            font-family: 'Inter', sans-serif;
            border-radius: 2px;
        }

        .comment-form .comment-submit:hover {
            background: #b3002e;
        }

        /* ============================================================
           RODAPÉ
           ============================================================ */
        .footer {
            border-top: 1px solid #1a1a1a;
            padding: 28px 40px;
            display: flex;
            flex-wrap: wrap;
            justify-content: space-between;
            align-items: center;
            gap: 16px;
            background: #0a0a0a;
            margin: 0 -40px -40px;
            padding-left: 40px;
            padding-right: 40px;
        }

        .footer .copy {
            font-size: 13px;
            color: #444;
        }

        .footer .copy strong {
            color: #666;
        }

        .footer-links {
            display: flex;
            gap: 20px;
            font-size: 13px;
            color: #555;
        }

        .footer-links a:hover {
            color: #cc0033;
        }

        .footer-links .age {
            color: #cc0033;
            font-weight: 700;
        }

        /* ============================================================
           EMPTY STATE
           ============================================================ */
        .empty-state {
            text-align: center;
            padding: 50px 20px;
            color: #555;
            grid-column: 1/-1;
        }

        .empty-state .icon-wrap {
            margin-bottom: 12px;
            color: #2a2a2a;
        }

        .empty-state .icon-wrap svg {
            width: 56px;
            height: 56px;
            fill: none;
            stroke: currentColor;
            stroke-width: 1.5;
            stroke-linecap: round;
            stroke-linejoin: round;
        }

        .empty-state .text {
            font-size: 17px;
        }

        .empty-state .sub {
            font-size: 14px;
            color: #444;
            margin-top: 4px;
        }

        /* ============================================================
           RESPONSIVO
           ============================================================ */
        @media (max-width: 1024px) {
            .hero-banner .banner-content p {
                font-size: 16px;
            }
        }

        @media (max-width: 768px) {
            .header {
                padding: 12px 16px;
            }

            .header-nav {
                gap: 14px;
                font-size: 13px;
            }

            .header-nav .badge {
                font-size: 10px;
                padding: 2px 10px;
            }

            .hero-banner {
                height: 50vh;
                min-height: 320px;
            }

            .hero-banner .banner-content {
                bottom: 15%;
                left: 20px;
                right: 20px;
                max-width: 100%;
            }

            .hero-banner .banner-content .logo-banner {
                max-height: 50px;
            }

            .hero-banner .banner-content p {
                font-size: 15px;
            }

            .main-content {
                padding: 0 16px 20px;
                margin-top: -20px;
            }

            .video-grid {
                grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
                gap: 14px;
            }

            .section-header h2 {
                font-size: 18px;
            }

            .modal-content {
                padding: 16px;
            }

            .modal-content .modal-title {
                font-size: 20px;
            }

            .footer {
                padding: 20px 16px;
                margin: 0 -16px -20px;
                flex-direction: column;
                text-align: center;
            }

            .footer-links {
                justify-content: center;
                gap: 14px;
            }

            .hero-banner .banner-content .btn-play,
            .hero-banner .banner-content .btn-info {
                padding: 10px 20px;
                font-size: 14px;
            }

            .filter-bar {
                gap: 6px;
            }

            .filter-btn {
                padding: 4px 14px;
                font-size: 12px;
            }
        }

        @media (max-width: 480px) {
            .header {
                padding: 10px 12px;
            }

            .logo img {
                height: 30px;
            }

            .header-nav {
                gap: 10px;
                font-size: 12px;
            }

            .hero-banner {
                height: 40vh;
                min-height: 260px;
            }

            .hero-banner .banner-content p {
                font-size: 14px;
            }

            .video-grid {
                grid-template-columns: 1fr 1fr;
                gap: 10px;
            }

            .video-card .info .title {
                font-size: 13px;
            }

            .video-card .info .meta {
                font-size: 11px;
            }

            .hero-banner .banner-content .banner-tags span {
                font-size: 10px;
                padding: 2px 10px;
            }

            .hero-banner .banner-content .btn-play,
            .hero-banner .banner-content .btn-info {
                padding: 8px 16px;
                font-size: 13px;
            }

            .hero-banner .banner-content .btn-play svg,
            .hero-banner .banner-content .btn-info svg {
                width: 16px;
                height: 16px;
            }

            .modal-content .modal-actions {
                flex-wrap: wrap;
            }

            .like-btn {
                padding: 6px 16px;
                font-size: 13px;
            }
        }
    </style>
</head>
<body>

    <!-- ============================================================
    HEADER - ESTILO NETFLIX
    ============================================================ -->
    <header class="header" id="header">
        <div class="logo">
            <!-- Substitua pelo link da sua logo -->
            <img src="https://i.ibb.co/xt4W4JPC/file-00000000d604720ea01dba00aa237277-3.png" alt="Xsess" />
        </div>
        <nav class="header-nav">
            <a href="#" class="active">Início</a>
            <a href="#">Categorias</a>
            <a href="#">Em Alta</a>
            <a href="#">Novos</a>
            <span class="badge">18+</span>
        </nav>
        <div class="header-actions">
            <button class="search-btn" aria-label="Buscar">
                <svg viewBox="0 0 24 24">
                    <circle cx="11" cy="11" r="8" stroke="currentColor" />
                    <line x1="21" y1="21" x2="16.65" y2="16.65" stroke="currentColor" />
                </svg>
            </button>
        </div>
    </header>

    <!-- ============================================================
    HERO BANNER - ESTILO NETFLIX
    ============================================================ -->
    <section class="hero-banner">
        <!-- Substitua pelo link da sua imagem de banner -->
        <img class="banner-image" src="https://i.ibb.co/nsVn4TS8/file-00000000673c720eb9c896f40e3edc10.jpg" alt="Banner Xsess" />
        <div class="banner-overlay"></div>
        <div class="banner-content">
            <img class="logo-banner" src="https://i.ibb.co/xt4W4JPC/file-00000000d604720ea01dba00aa237277-3.png" alt="Xsess" />
            <p>Vídeos exclusivos com qualidade profissional. Acesso direto, sem cadastro.</p>
            <div class="banner-tags">
                <span>4K</span>
                <span>Exclusivo</span>
                <span>Novo</span>
            </div>
            <div class="banner-buttons">
                <button class="btn-play" onclick="scrollToContent()">
                    <svg viewBox="0 0 24 24">
                        <polygon points="5 3 19 12 5 21 5 3" stroke="currentColor" />
                    </svg>
                    Assistir Agora
                </button>
                <button class="btn-info" onclick="alert('Em breve mais informações!')">
                    <svg viewBox="0 0 24 24">
                        <circle cx="12" cy="12" r="10" stroke="currentColor" />
                        <line x1="12" y1="16" x2="12" y2="12" stroke="currentColor" />
                        <circle cx="12" cy="8" r="0.5" fill="currentColor" stroke="none" />
                    </svg>
                    Mais Info
                </button>
            </div>
        </div>
    </section>

    <!-- ============================================================
    CONTEÚDO PRINCIPAL
    ============================================================ -->
    <div class="main-content" id="mainContent">

        <!-- ============================================================
        SEÇÃO: FILTROS
        ============================================================ -->
        <div class="section">
            <div class="section-header">
                <h2>🎬 <span>Destaques</span></h2>
                <span class="see-all" onclick="document.querySelectorAll('.filter-btn')[0].click()">Ver todos</span>
            </div>
            <div class="filter-bar">
                <button class="filter-btn active" data-filter="all">Todos</button>
                <button class="filter-btn" data-filter="Exclusivo">Exclusivo</button>
                <button class="filter-btn" data-filter="4K">4K</button>
                <button class="filter-btn" data-filter="Novo">Novo</button>
                <button class="filter-btn" data-filter="Em Alta">Em Alta</button>
                <button class="filter-btn" data-filter="Premium">Premium</button>
            </div>
        </div>

        <!-- ============================================================
        GRID DE VÍDEOS
        ============================================================ -->
        <div class="section">
            <div class="video-grid" id="videoGrid">
                <!-- Renderizado pelo JavaScript -->
            </div>
        </div>

        <!-- ============================================================
        RODAPÉ
        ============================================================ -->
        <footer class="footer">
            <div class="copy">&copy; 2026 <strong>Xsess</strong> · Todos os direitos reservados</div>
            <div class="footer-links">
                <a href="#">Termos de Uso</a>
                <a href="#">Política de Privacidade</a>
                <a href="#">Contato</a>
                <span class="age">18+</span>
            </div>
        </footer>

    </div>

    <!-- ============================================================
    MODAL DO VÍDEO
    ============================================================ -->
    <div class="modal" id="videoModal">
        <div class="modal-content">
            <button class="close" id="closeModal">✕</button>

            <div class="player" id="modalPlayer">
                <!-- Player será inserido aqui -->
            </div>

            <h2 class="modal-title" id="modalTitle">Título do Vídeo</h2>
            <div class="modal-author" id="modalAuthor">Criador: <span>Xsess Creator</span></div>

            <div class="modal-meta" id="modalMeta">
                <span id="modalDate">00/00/0000</span>
                <span class="tag" id="modalTag">Exclusivo</span>
            </div>

            <div class="modal-desc" id="modalDesc">Descrição do vídeo...</div>

            <div class="modal-actions">
                <button class="like-btn" id="modalLikeBtn">
                    <svg viewBox="0 0 24 24">
                        <path d="M14 9V5a3 3 0 00-3-3l-4 9v11h11.28a2 2 0 002-1.7l1.38-9a2 2 0 00-2-2.3zM7 22H4a2 2 0 01-2-2v-7a2 2 0 012-2h3" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                    Curtir
                </button>
                <span class="like-count" id="modalLikeCount">0</span>
            </div>

            <!-- ===== COMENTÁRIOS ===== -->
            <div class="comments-section">
                <h3>
                    <svg viewBox="0 0 24 24">
                        <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                    Comentários
                </h3>
                <div id="modalComments">
                    <!-- Comentários serão carregados aqui -->
                </div>

                <form class="comment-form" id="commentForm">
                    <input type="text" id="commentName" placeholder="Seu nome" required />
                    <textarea id="commentText" placeholder="Escreva seu comentário..." rows="3" required></textarea>
                    <button type="submit" class="comment-submit">Enviar Comentário</button>
                </form>
            </div>
        </div>
    </div>

    <!-- ============================================================
    JAVASCRIPT COMPLETO
    ============================================================ -->
    <script>
        // ============================================================
        // HEADER SCROLL EFFECT
        // ============================================================
        const header = document.getElementById('header');
        window.addEventListener('scroll', () => {
            if (window.scrollY > 50) {
                header.classList.add('scrolled');
            } else {
                header.classList.remove('scrolled');
            }
        });

        // ============================================================
        // SCROLL TO CONTENT
        // ============================================================
        function scrollToContent() {
            document.getElementById('mainContent').scrollIntoView({ behavior: 'smooth', block: 'start' });
        }

        // ============================================================
        // BANCO DE DADOS (localStorage)
        // ============================================================
        const DB = {
            get(key, def) {
                try {
                    const data = localStorage.getItem('xsess_' + key);
                    return data ? JSON.parse(data) : def;
                } catch {
                    return def;
                }
            },
            set(key, value) {
                localStorage.setItem('xsess_' + key, JSON.stringify(value));
            }
        };

        // ============================================================
        // ESTADO
        // ============================================================
        let videos = DB.get('videos', []);
        let likes = DB.get('likes', {});
        let comments = DB.get('comments', {});
        let likedVideos = DB.get('likedVideos', []);
        let currentFilter = 'all';
        let currentVideoId = null;

        // ============================================================
        // DOM REFS
        // ============================================================
        const $ = (id) => document.getElementById(id);
        const grid = $('videoGrid');
        const modal = $('videoModal');
        const modalPlayer = $('modalPlayer');
        const modalTitle = $('modalTitle');
        const modalAuthor = $('modalAuthor');
        const modalDate = $('modalDate');
        const modalTag = $('modalTag');
        const modalDesc = $('modalDesc');
        const modalLikeBtn = $('modalLikeBtn');
        const modalLikeCount = $('modalLikeCount');
        const modalComments = $('modalComments');
        const closeModalBtn = $('closeModal');

        // ============================================================
        // FUNÇÕES AUXILIARES
        // ============================================================
        function formatDate() {
            const now = new Date();
            return now.toLocaleDateString('pt-BR') + ' ' + now.toLocaleTimeString('pt-BR', { hour: '2-digit',
                minute: '2-digit' });
        }

        function getVideoEmbed(url) {
            // YouTube
            const yt = url.match(/(?:youtube\.com\/(?:[^\/]+\/.+\/|(?:v|e(?:mbed)?)\/|.*[?&]v=)|youtu\.be\/)([^"&?\/\s]{11})/);
            if (yt) return `<iframe src="https://www.youtube.com/embed/${yt[1]}?autoplay=1&rel=0" allow="autoplay; encrypted-media" allowfullscreen></iframe>`;

            // Vimeo
            const vimeo = url.match(/vimeo\.com\/(\d+)/);
            if (vimeo) return `<iframe src="https://player.vimeo.com/video/${vimeo[1]}?autoplay=1" allow="autoplay; encrypted-media" allowfullscreen></iframe>`;

            // Google Drive
            const drive = url.match(/drive\.google\.com\/file\/d\/([^\/]+)/);
            if (drive) return `<iframe src="https://drive.google.com/file/d/${drive[1]}/preview" allow="autoplay" allowfullscreen></iframe>`;

            // Link direto (vídeo)
            if (url.match(/\.(mp4|webm|mov|avi)$/i)) {
                return `<video controls autoplay style="width:100%;height:100%;background:#000;">
                            <source src="${url}" type="video/mp4">
                            Seu navegador não suporta vídeo.
                        </video>`;
            }

            // Qualquer outro link - tentar embed genérico
            return `<iframe src="${url}" allow="autoplay" allowfullscreen></iframe>`;
        }

        // ============================================================
        // RENDERIZAR VÍDEOS
        // ============================================================
        function renderVideos(filter = 'all') {
            grid.innerHTML = '';

            let filtered = videos;
            if (filter !== 'all') {
                filtered = videos.filter(v =>
                    v.tags && v.tags.some(t => t.toLowerCase() === filter.toLowerCase())
                );
            }

            if (filtered.length === 0) {
                grid.innerHTML = `
                            <div class="empty-state">
                                <div class="icon-wrap">
                                    <svg viewBox="0 0 24 24">
                                        <rect x="2" y="3" width="20" height="14" rx="2" stroke="currentColor" />
                                        <polygon points="10 7 16 10 10 13 10 7" stroke="currentColor" />
                                    </svg>
                                </div>
                                <div class="text">Nenhum vídeo encontrado</div>
                                <div class="sub">${filter === 'all' ? 'Nenhum vídeo publicado ainda.' : 'Nenhum vídeo com este filtro.'}</div>
                            </div>
                        `;
                return;
            }

            filtered.forEach(video => {
                const card = document.createElement('div');
                card.className = 'video-card';
                card.dataset.id = video.id;

                const tagsHtml = video.tags ? video.tags.slice(0, 2).map(tag =>
                    `<span class="tag">${tag}</span>`
                ).join('') : '';

                card.innerHTML = `
                            <div class="thumb">
                                <img src="${video.thumbnail || 'https://via.placeholder.com/640x360/1a1a1a/cc0033?text=Sem+Imagem'}" alt="${video.title}" loading="lazy" />
                                <div class="overlay">
                                    <svg class="play-icon" viewBox="0 0 24 24">
                                        <circle cx="12" cy="12" r="10" stroke="currentColor" />
                                        <polygon points="10,8 16,12 10,16" fill="white" stroke="none" />
                                    </svg>
                                </div>
                                <span class="duration">${video.duration || '--:--'}</span>
                            </div>
                            <div class="info">
                                <div class="title">${video.title}</div>
                                <div class="meta">
                                    <span>${video.date || ''}</span>
                                    ${tagsHtml}
                                </div>
                                <div class="author">Criador: <span>${video.author || 'Xsess'}</span></div>
                            </div>
                        `;

                card.addEventListener('click', () => openModal(video.id));
                grid.appendChild(card);
            });
        }

        // ============================================================
        // ABRIR MODAL
        // ============================================================
        function openModal(videoId) {
            const video = videos.find(v => v.id === videoId);
            if (!video) return;

            currentVideoId = videoId;

            // Player
            modalPlayer.innerHTML = getVideoEmbed(video.link || '');

            // Título e autor
            modalTitle.textContent = video.title;
            modalAuthor.innerHTML = `Criador: <span>${video.author || 'Xsess'}</span>`;

            // Meta
            modalDate.textContent = video.date || '';
            const firstTag = video.tags && video.tags.length > 0 ? video.tags[0] : 'Geral';
            modalTag.textContent = firstTag;

            // Descrição
            modalDesc.textContent = video.description || 'Sem descrição.';

            // Curtidas
            const likesCount = likes[videoId] || 0;
            modalLikeCount.textContent = likesCount;

            if (likedVideos.includes(videoId)) {
                modalLikeBtn.classList.add('liked');
                modalLikeBtn.innerHTML = `
                            <svg viewBox="0 0 24 24" fill="currentColor">
                                <path d="M14 9V5a3 3 0 00-3-3l-4 9v11h11.28a2 2 0 002-1.7l1.38-9a2 2 0 00-2-2.3zM7 22H4a2 2 0 01-2-2v-7a2 2 0 012-2h3" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" />
                            </svg>
                            Curtido
                        `;
            } else {
                modalLikeBtn.classList.remove('liked');
                modalLikeBtn.innerHTML = `
                            <svg viewBox="0 0 24 24">
                                <path d="M14 9V5a3 3 0 00-3-3l-4 9v11h11.28a2 2 0 002-1.7l1.38-9a2 2 0 00-2-2.3zM7 22H4a2 2 0 01-2-2v-7a2 2 0 012-2h3" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" />
                            </svg>
                            Curtir
                        `;
            }

            // Comentários
            renderComments(videoId);

            // Abrir modal
            modal.classList.add('active');
            document.body.style.overflow = 'hidden';
        }

        // ============================================================
        // FECHAR MODAL
        // ============================================================
        function closeModal() {
            modal.classList.remove('active');
            document.body.style.overflow = '';
            modalPlayer.innerHTML = '';
            currentVideoId = null;
        }

        // ============================================================
        // RENDERIZAR COMENTÁRIOS
        // ============================================================
        function renderComments(videoId) {
            const videoComments = comments[videoId] || [];

            if (videoComments.length === 0) {
                modalComments.innerHTML = `
                            <p style="color:#666;font-size:14px;padding:12px 0;">Nenhum comentário ainda. Seja o primeiro!</p>
                        `;
                return;
            }

            modalComments.innerHTML = videoComments.map(c => `
                        <div class="comment">
                            <div class="comment-author">${c.name}</div>
                            <div class="comment-content">${c.text}</div>
                            <div class="comment-date">${c.date}</div>
                        </div>
                    `).join('');
        }

        // ============================================================
        // ENVIAR COMENTÁRIO
        // ============================================================
        function submitComment(videoId, name, text) {
            if (!comments[videoId]) comments[videoId] = [];
            comments[videoId].push({
                name: name.trim(),
                text: text.trim(),
                date: formatDate()
            });
            DB.set('comments', comments);
            renderComments(videoId);

            // Limpar formulário
            $('commentName').value = '';
            $('commentText').value = '';
        }

        // ============================================================
        // CURTIR VÍDEO
        // ============================================================
        function toggleLike(videoId) {
            if (!likes[videoId]) likes[videoId] = 0;

            if (likedVideos.includes(videoId)) {
                likedVideos = likedVideos.filter(id => id !== videoId);
                likes[videoId] = Math.max(0, likes[videoId] - 1);
                modalLikeBtn.classList.remove('liked');
                modalLikeBtn.innerHTML = `
                            <svg viewBox="0 0 24 24">
                                <path d="M14 9V5a3 3 0 00-3-3l-4 9v11h11.28a2 2 0 002-1.7l1.38-9a2 2 0 00-2-2.3zM7 22H4a2 2 0 01-2-2v-7a2 2 0 012-2h3" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" />
                            </svg>
                            Curtir
                        `;
            } else {
                likedVideos.push(videoId);
                likes[videoId] = (likes[videoId] || 0) + 1;
                modalLikeBtn.classList.add('liked');
                modalLikeBtn.innerHTML = `
                            <svg viewBox="0 0 24 24" fill="currentColor">
                                <path d="M14 9V5a3 3 0 00-3-3l-4 9v11h11.28a2 2 0 002-1.7l1.38-9a2 2 0 00-2-2.3zM7 22H4a2 2 0 01-2-2v-7a2 2 0 012-2h3" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" />
                            </svg>
                            Curtido
                        `;
            }

            DB.set('likes', likes);
            DB.set('likedVideos', likedVideos);
            modalLikeCount.textContent = likes[videoId];
        }

        // ============================================================
        // EVENTOS
        // ============================================================

        // Filtros
        document.querySelectorAll('.filter-btn').forEach(btn => {
            btn.addEventListener('click', function() {
                document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
                this.classList.add('active');
                currentFilter = this.dataset.filter;
                renderVideos(currentFilter);
            });
        });

        // Curtir
        modalLikeBtn.addEventListener('click', function() {
            if (currentVideoId) toggleLike(currentVideoId);
        });

        // Fechar modal
        closeModalBtn.addEventListener('click', closeModal);
        modal.addEventListener('click', function(e) {
            if (e.target === this) closeModal();
        });
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') closeModal();
        });

        // Enviar comentário
        $('commentForm').addEventListener('submit', function(e) {
            e.preventDefault();
            const name = $('commentName').value.trim();
            const text = $('commentText').value.trim();
            if (!name || !text || !currentVideoId) return;
            submitComment(currentVideoId, name, text);
        });

        // ============================================================
        // INICIAR
        // ============================================================
        renderVideos('all');
    </script>

</body>
</html>
